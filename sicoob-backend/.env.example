# =============================================================================
# Configuração do backend de integração com o Sicoob
# Copie este arquivo para ".env" e preencha. NUNCA versione o ".env" real.
# =============================================================================

# Porta do servidor local
PORT=3333

# Origem permitida (CORS) — o endereço do Sistema Financeiro no navegador.
# Em produção, aponte para https://diagnostika-engenharia.github.io
CORS_ORIGIN=http://localhost:5500

# Chave simples para proteger o backend (o frontend envia no header X-API-Key).
# Gere um valor aleatório forte. Em produção, prefira um mecanismo de auth real.
API_KEY=troque-esta-chave

# -----------------------------------------------------------------------------
# AMBIENTE: "sandbox" ou "producao"
# -----------------------------------------------------------------------------
SICOOB_ENV=sandbox

# Número da conta corrente (sem dígito, conforme exigido pela API)
SICOOB_CONTA=00000000

# -----------------------------------------------------------------------------
# SANDBOX
# No sandbox o Sicoob fornece um access_token fixo e NÃO exige mTLS.
# Pegue o token de teste no portal: https://developers.sicoob.com.br
# -----------------------------------------------------------------------------
SICOOB_SANDBOX_TOKEN=
SICOOB_SANDBOX_CLIENT_ID=

# -----------------------------------------------------------------------------
# PRODUÇÃO (preencher só quando tiver as credenciais reais)
# Exige OAuth2 client_credentials + certificado digital (mTLS).
# -----------------------------------------------------------------------------
SICOOB_CLIENT_ID=
SICOOB_SCOPES=cco_saldo cco_extrato openid

# Caminho para o certificado .pfx (chave privada) e sua senha.
# Esses arquivos ficam SOMENTE no servidor, jamais no frontend.
SICOOB_PFX_PATH=./certs/certificado.pfx
SICOOB_PFX_PASSWORD=
